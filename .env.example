# NexoAccManager Backend - Environment Variables
# Copy this file to .env and fill in your values

# Database
# Local (SQLite): DATABASE_URL="file:./dev.db", DATABASE_PROVIDER="sqlite"
# Production (PostgreSQL): DATABASE_URL="postgresql://user:pass@host:5432/db", DATABASE_PROVIDER="postgresql"
DATABASE_URL="file:./dev.db"
DATABASE_PROVIDER="sqlite"

# JWT secrets (RSA-256 key pair for signing)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_SECRET="your-secret-here"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (SMTP)
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER="user@ethereal.email"
SMTP_PASS="password"
EMAIL_FROM="noreply@nexoaccmanager.com"

# Frontend URL (for CORS)
FRONTEND_URL="https://nexoaccmanager.com"

# Server
PORT="3000"
NODE_ENV="production"